body {
    margin: 0;
    padding: 0;
    overflow: hidden;
    background-color: #0a0a0a;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    font-family: 'Arial Black', sans-serif;
}

#ui {
    position: absolute;
    top: 20px;
    color: #00ffcc;
    text-align: center;
    pointer-events: none;
    z-index: 10;
}

canvas {
    border: 4px solid #333;
    border-radius: 10px;
    box-shadow: 0 0 20px rgba(0, 255, 204, 0.3);
}
